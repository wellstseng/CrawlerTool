# config.simulation.ini  — 玉山證券 模擬環境設定檔範本
#
# 用法：
#   1. 從「交易 API 金鑰網站」下載官方的 config.simulation.ini.example（內含你的 Key/Secret）
#   2. 改名為 config.simulation.ini
#   3. [Cert] Path 填入你匯出的憑證檔（ID_DATE.p12）的路徑
#   4. [Api] Key / Secret、[User] Account 用官方下載的那份覆蓋掉下面的 XXXX
#
# 注意：真正的 config.simulation.ini 內含金鑰，已被 .gitignore 排除，不會進版控。

[Core]
Entry = https://esuntradingapi-simulation.esunsec.com.tw/api/v1
Environment = SIMULATION

[Cert]
# 你的憑證檔路徑，例：./ID_DATE.p12
Path =

[Api]
Key = XXXXXXXXXXXXXXXX
Secret = XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

[User]
Account = 884XXXXXXXX
